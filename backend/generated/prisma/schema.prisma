generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id        String   @id
  type      String
  status    String
  payload   Json
  result    Json?
  error     String?
  createdAt DateTime
  updatedAt DateTime
}

model Page {
  id              String        @id
  sourceType      String
  status          String
  sourceUrl       String?
  publicUrl       String?
  latestVersionId String?
  createdAt       DateTime
  updatedAt       DateTime
  versions        PageVersion[]
}

model PageVersion {
  id        String   @id
  pageId    String
  title     String
  html      String
  meta      Json
  createdAt DateTime
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}
