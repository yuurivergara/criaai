# Em Windows, se o Docker estiver no ar e ainda assim aparecer P1001 com
# `localhost`, use 127.0.0.1 (Node costuma resolver localhost -> ::1 antes do IPv4).
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/criaai?schema=public"
REDIS_URL="redis://127.0.0.1:6379"
# Origens permitidas no browser (Vite). Separe por vírgula; se vazio, usa defaults em main.ts.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
DB_STRICT_MODE="true"

# URL pública do quiz (sem barra no final). Em produção use o domínio da CriaAI
# que aponta para esta API, ex.: https://app.criaai.app/v1/public
# Se vazio, usa PUBLIC_BASE_URL; se os dois vazios, cai no localhost abaixo.
CRIAAI_PUBLIC_PAGE_BASE_URL=""
# PUBLIC_BASE_URL="http://localhost:3000/v1/public"

# Hostname usado nas instruções de CNAME de domínio próprio (TXT/CNAME).
# CRIAAI_PUBLIC_HOST="app.criaai.app"

# LLM externo (opcional — usado apenas se Ollama não estiver disponível).
LLM_API_URL=""
LLM_API_KEY=""
LLM_TIMEOUT_MS="10000"
LLM_MAX_RETRIES="2"
LLM_BASE_RETRY_DELAY_MS="250"
LLM_CIRCUIT_BREAKER_FAILURE_THRESHOLD="3"
LLM_CIRCUIT_BREAKER_COOLDOWN_MS="10000"

# Ollama local (zero custo). Rode `npm run llm:setup` pra instalar + puxar modelo.
# Default troca pro 3B (~3GB RAM, ~2GB de download). Se sua máquina aguenta o 7B
# (~6GB RAM, ~4GB de download) e a qualidade do 3B não tiver dando conta, troque
# pra "qwen2.5:7b-instruct".
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:3b-instruct"
OLLAMA_TIMEOUT_MS="30000"
